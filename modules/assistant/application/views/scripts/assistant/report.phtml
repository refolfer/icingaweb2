<div class="content">
    <p class="assistant-report-prefill-hint">
        <?= $this->escape($this->prefillHint) ?>
    </p>

    <?= $this->form ?>
</div>

<?php if (! empty($this->reportletValue)): ?>
<script>
(function (document) {
    var desired = <?= json_encode($this->reportletValue) ?>;
    var select = document.querySelector('select[name="reportlet"]');

    if (! desired || ! select) {
        return;
    }

    if (select.value !== desired) {
        select.value = desired;
        if (typeof Event === 'function') {
            select.dispatchEvent(new Event('change', { bubbles: true }));
        }
    }
})(document);
</script>
<?php endif ?>
